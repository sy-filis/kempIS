{
  "name": "kempis-fe",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:en": "ng serve --configuration=en",
    "dev": "concurrently --names cs,en --prefix-colors \"green.bold,blue.bold\" \"npm:start\" \"npm:start:en\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "extract-i18n": "ng extract-i18n --output-path src/locale --format xlf2"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@angular/service-worker": "21.2.11",
    "@primeng/themes": "^21.0.4",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "signality": "^0.0.1",
    "signature_pad": "^5.1.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@angular/localize": "^21.2.11",
    "@eslint/js": "^10.0.1",
    "@primeng/mcp": "^21.1.3",
    "@types/qrcode": "^1.5.6",
    "angular-eslint": "21.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  }
}
