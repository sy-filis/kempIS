WEBAPI_IMAGE=kempis/web-api:local
FRONTEND_IMAGE=kempis/frontend:local
CADDY_IMAGE=kempis/caddy:local
WEBAPI_PULL_POLICY=missing
FRONTEND_PULL_POLICY=missing
CADDY_PULL_POLICY=missing

TZ=Europe/Prague

POSTGRES_DB=kempis
POSTGRES_USER=kempis
POSTGRES_PASSWORD=replace-with-strong-secret

# Cloudflare API token, Zone:DNS:Edit on the LAN and WAN zones.
CLOUDFLARE_API_TOKEN=

LAN_BIND_ADDRESS=0.0.0.0
LAN_HTTP_PORT=80
LAN_HTTPS_PORT=443
CADDY_LAN_DOMAIN=kempis.example.com
CADDY_LAN_EMAIL=ops@example.com

WAN_BIND_ADDRESS=0.0.0.0
WAN_HTTP_PORT=80
WAN_HTTPS_PORT=443
CADDY_WAN_DOMAIN=api.example.com
CADDY_WAN_EMAIL=ops@example.com

# Iframe embedding on the public proxy. Leave 'none' to block. To allow,
# set both: WAN_FRAME_ANCESTORS="'self' https://www.example.com" and
# WAN_CORP=cross-origin.
WAN_FRAME_ANCESTORS='none'
WAN_CORP=same-site

TUNNEL_TOKEN=
