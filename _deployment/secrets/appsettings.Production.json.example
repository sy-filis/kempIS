{
  "_comment": "Copy this file to appsettings.Production.json (sibling at repo root) and fill in the values. docker-compose.prod.yml mounts it read-only at /app/appsettings.Production.json. Keys with empty/placeholder values MUST be filled in; ValidateOnStart rejects startup if Camp/Retention/Frontend sections are blank.",

  "ConnectionStrings": {
    "Database": "Host=postgres;Port=5432;Database=kempis;Username=kempis;Password=REPLACE-WITH-STRONG-SECRET;Include Error Detail=false",
    "Redis": "redis:6379"
  },

  "Camp": {
    "Name": "ATC Olsovec",
    "Street": "Kopecek",
    "City": "Jedovnice",
    "ZipCode": "679 06",
    "Cin": "12345678",
    "Tin": "CZ12345678",
    "Phone": "+420 516 442 216",
    "Email": "info@atcolsovec.cz",
    "Web": "https://www.atcolsovec.cz",
    "CheckOutTime": "11:00:00"
  },

  "Retention": {
    "GuestYears": 6,
    "BillYears": 10,
    "InvoiceYears": 10,
    "RunAtLocalTime": "03:00:00"
  },

  "Frontend": {
    "BaseUrl": "https://app.example.com"
  },

  "Cors": {
    "AllowedOrigins": [ "https://app.example.com" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ],
    "ExposedHeaders": [],
    "AllowCredentials": true
  },

  "Identity": {
    "Passkeys": {
      "ServerDomain": "example.com",
      "AllowedOrigins": [
        "https://app.example.com",
        "https://api.example.com"
      ]
    }
  },

  "BearerToken": {
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationMinutes": 720,
    "SessionAbsoluteExpirationMinutes": 720
  },

  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "no-reply@example.com",
    "Password": "REPLACE-WITH-SECRET",
    "FromAddress": "no-reply@example.com",
    "FromName": "Kemp IS",
    "Security": "StartTls"
  },

  "Ares": {
    "BaseUrl": "https://ares.gov.cz/ekonomicke-subjekty-v-be/rest/ekonomicke-subjekty/"
  },
  "Ruian": {
    "BaseUrl": "https://ags.cuzk.cz/arcgis/rest/services/RUIAN/MapServer/exts/GeocodeSOE/"
  },
  "Mapy": {
    "BaseUrl": "https://api.mapy.com/v1/",
    "ApiKey": "REPLACE-WITH-API-KEY"
  },

  "Ubyport": {
    "EndpointUrl": "https://ubyport.pcr.cz/ws_uby/ws_uby.svc",
    "Username": "",
    "Password": "",
    "AuthenticationCode": "",
    "IdUb": 0,
    "Mark": "",
    "Name": "",
    "Contact": "",
    "District": "",
    "Town": "",
    "TownPart": null,
    "Street": "",
    "HouseNumber": "",
    "OrientationNumber": null,
    "Zip": ""
  },

  "EDoklady": {
    "BaseUrl": "https://capi.edoklady.gov.cz/",
    "Certificate": {
      "PfxPath": "/etc/kempis/edoklady.pfx",
      "PfxPassword": "REPLACE-WITH-SECRET"
    },
    "QrCodeRefreshThresholdDays": 7,
    "Geolocation": null
  },

  "GateSystem": {
    "BaseUrl": "",
    "TimeoutSeconds": 5
  },

  "Reception": {
    "SocketIoPort": 9001,
    "PairCodeTtlSeconds": 120,
    "TabletJoinGraceSeconds": 10,
    "SessionPushMaxBytes": 65536,
    "SignaturePngMaxBytes": 262144,
    "DefaultEventMaxBytes": 16384,
    "AllowlistSweepIntervalSeconds": 60
  }
}
